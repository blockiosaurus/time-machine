# =============================================================================
# Metaplex Agent Template -- Environment Variables
#
# Variables are grouped by which AGENT_MODE they apply to. If you're building
# a single-mode agent, skim only the "BOTH MODES" section plus the section
# for your chosen mode -- the other mode's section is safe to ignore.
#
# Inline tags:
#   REQUIRED             -- must be set before starting the server
#   OPTIONAL (default)   -- safe to omit; default shown
#   OPTIONAL (no default) -- only set if you need the feature
#
# See docs/SPEC.md §8.1 for the canonical reference.
# =============================================================================


# #############################################################################
# BOTH MODES
# Variables every agent needs regardless of public vs autonomous.
# #############################################################################

# -----------------------------------------------------------------------------
# Mode selection
# -----------------------------------------------------------------------------

# "public" (users sign their own txs) or "autonomous" (agent signs everything).
# See README §"Which mode am I?" for help choosing.
AGENT_MODE=public                               # OPTIONAL (default: public)


# -----------------------------------------------------------------------------
# Identity (agent keypair)
# -----------------------------------------------------------------------------

# Agent keypair. REQUIRED in both modes -- the agent always has a keypair that
# signs registration, delegation, and treasury ops.
# Accepts a base58-encoded secret key OR a JSON byte array like [1,2,3,...].
# Generate one with: solana-keygen new --no-bip39-passphrase --outfile /dev/stdout
AGENT_KEYPAIR=                                  # REQUIRED


# -----------------------------------------------------------------------------
# WebSocket auth
# -----------------------------------------------------------------------------

# Shared secret for WebSocket authentication. Must be at least 32 characters.
# Generate with:
#   openssl rand -hex 24   # 48 hex chars (recommended minimum)
#   openssl rand -hex 32   # 64 hex chars
WEB_CHANNEL_TOKEN=                              # REQUIRED (>= 32 chars)


# -----------------------------------------------------------------------------
# LLM (one API key required, matching the provider prefix in LLM_MODEL)
# -----------------------------------------------------------------------------

# Model identifier using Mastra's provider/model format.
# Examples: anthropic/claude-sonnet-4-5-20250929, openai/gpt-4o, google/gemini-2.5-pro
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929  # OPTIONAL (default shown)

# Set the API key matching your LLM_MODEL provider. Exactly one is REQUIRED.
ANTHROPIC_API_KEY=                              # REQUIRED (if using Anthropic)
# OPENAI_API_KEY=                               # REQUIRED (if using OpenAI)
# GOOGLE_GENERATIVE_AI_API_KEY=                 # REQUIRED (if using Google)


# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Solana JSON-RPC endpoint. Devnet default is rate-limited; use Helius/
# QuickNode/Triton etc. in production.
SOLANA_RPC_URL=https://api.devnet.solana.com    # OPTIONAL (default shown)


# -----------------------------------------------------------------------------
# WebSocket server
# -----------------------------------------------------------------------------

WEB_CHANNEL_PORT=3002                           # OPTIONAL (default: 3002)
ASSISTANT_NAME=Agent                            # OPTIONAL (default: Agent)

# Max concurrent WebSocket sessions the server will accept.
MAX_CONNECTIONS=10                              # OPTIONAL (default: 10)

# Stream debug:* telemetry events (step_start, tool_call, tool_result, ...).
ENABLE_DEBUG_EVENTS=true                        # OPTIONAL (default: true)

# Comma-separated list of allowed WebSocket `Origin` headers (CSWSH protection).
# Tighten this in production to the actual UI origins.
WS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000  # OPTIONAL (default shown)

# Per-message character cap on inbound chat `content`.
MAX_MESSAGE_CONTENT=8000                        # OPTIONAL (default: 8000)

# Per-message cumulative RPC wall-clock budget (ms). Bounds runaway tool loops.
MAX_RPC_TIME_BUDGET_MS=60000                    # OPTIONAL (default: 60000)

# Emit structured console.warn logs on auth/origin/rate-limit failures.
LOG_AUTH_FAILURES=true                          # OPTIONAL (default: true)


# -----------------------------------------------------------------------------
# Agent runtime limits
# -----------------------------------------------------------------------------

# Max LLM + tool-execution steps per user message.
MAX_STEPS=10                                    # OPTIONAL (default: 10)

# Upper cap on `slippageBps` accepted by swap/buyback/sell tools.
MAX_SLIPPAGE_BPS=500                            # OPTIONAL (default: 500)

# Upper cap on Jupiter `priceImpactPct` before a quote is rejected.
MAX_PRICE_IMPACT_PCT=2.0                        # OPTIONAL (default: 2.0)

# TTL (ms) for the in-memory on-chain owner cache.
OWNER_CACHE_TTL_MS=300000                       # OPTIONAL (default: 300000)


# -----------------------------------------------------------------------------
# Identity overrides (auto-persisted to agent-state.json otherwise)
# -----------------------------------------------------------------------------

# Agent asset address on the Metaplex Agent Registry.
# Leave empty on first run; the agent will register itself and persist this.
AGENT_ASSET_ADDRESS=                            # OPTIONAL (no default)

# Agent token mint address. Leave empty; launch-token auto-persists it.
AGENT_TOKEN_MINT=                               # OPTIONAL (no default)

# Override the buyback target token (e.g. MPLX mint). When set, the agent
# skips launch-token and routes buyback/sell to this mint.
TOKEN_OVERRIDE=                                 # OPTIONAL (no default)


# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------

# Jupiter Price/Quote API key. Needed for price watching, portfolio analysis,
# and higher rate limits on swap quotes. Get one at https://developers.jup.ag
JUPITER_API_KEY=                                # OPTIONAL (no default)


# #############################################################################
# PUBLIC MODE ONLY  (AGENT_MODE=public)
# End users sign transactions in their browser wallet. Safe to ignore these
# in autonomous mode -- they have no effect there.
# #############################################################################

# -----------------------------------------------------------------------------
# Fee configuration
# -----------------------------------------------------------------------------

# SOL fee prepended to every user transaction once the agent is registered.
# Paid to the agent's PDA. Not used in autonomous mode.
AGENT_FEE_SOL=0.001                             # OPTIONAL (default: 0.001)


# -----------------------------------------------------------------------------
# Registration auto-funding
# -----------------------------------------------------------------------------
# When the agent's keypair is underfunded on first run, public mode asks the
# connected user wallet to send a small SOL top-up so registration can proceed.
# Autonomous-mode operators pre-fund the keypair themselves; these variables
# are inert there.

# SOL amount requested from the user during the auto-funding flow.
AGENT_FUNDING_SOL=0.02                          # OPTIONAL (default: 0.02)

# Balance threshold below which register-agent triggers the funding flow.
AGENT_FUNDING_THRESHOLD_SOL=0.01                # OPTIONAL (default: 0.01)


# #############################################################################
# AUTONOMOUS MODE ONLY  (AGENT_MODE=autonomous)
# The agent signs and submits transactions itself. Safe to ignore these in
# public mode.
# #############################################################################

# -----------------------------------------------------------------------------
# Bootstrap wallet
# -----------------------------------------------------------------------------
# The wallet allowed to connect and trigger the first register-agent call
# before the agent has an on-chain identity. REQUIRED in autonomous mode
# pre-registration -- the server refuses to start otherwise. Once the agent
# is registered, the on-chain asset owner takes precedence and this value is
# no longer consulted.
BOOTSTRAP_WALLET=                               # REQUIRED in autonomous mode pre-registration


# #############################################################################
# TIME MACHINE
# Product-specific configuration for the Time Machine character platform.
# #############################################################################

# Postgres connection string (Drizzle uses node-postgres under the hood).
# Local dev (managed by docker-compose, see `pnpm db:up`) — host port 5433
# to avoid colliding with system-wide Postgres on 5432:
#   postgresql://timemachine:timemachine@localhost:5433/timemachine
# Railway prod: leave commented; Railway injects DATABASE_URL automatically.
DATABASE_URL=postgresql://timemachine:timemachine@localhost:5433/timemachine  # REQUIRED

# OpenAI API key for character portrait generation (gpt-image-1).
# Distinct from OPENAI_API_KEY (which is for chat LLM, if using OpenAI as
# the chat provider). Set to the same key if you are using OpenAI for both.
OPENAI_IMAGE_API_KEY=                           # REQUIRED for portrait generation

# Irys uploads use the agent keypair (AGENT_KEYPAIR) as the payer via
# umi-uploader-irys; the Irys network is inferred from SOLANA_RPC_URL
# (devnet if the RPC contains "devnet", mainnet otherwise). Make sure the
# agent wallet is funded on the matching network.


# Public base URL of the Time Machine UI. Used to build links to statically
# hosted assets — e.g. the collection metadata JSON the on-chain asset
# points at lives at `${PUBLIC_BASE_URL}/collection/metadata.json`.
PUBLIC_BASE_URL=http://localhost:3001           # OPTIONAL (default: http://localhost:3001)

# Public base URL of the Time Machine SERVER (not the UI). On-chain
# resources (portrait, NFT metadata JSON, Agent Registry registration doc)
# are served by the server at this URL — must be publicly reachable.
# In production this is your Railway server's domain.
PUBLIC_API_URL=http://localhost:3002            # OPTIONAL (default: http://localhost:3002)

# Comma-separated base58 wallet addresses with /admin access.
ADMIN_WALLETS=DhYCi6pvfhJkPRpt5RjYwsE1hZw84iu6twbRt9B6dYLV  # REQUIRED for admin

# Mint fee in lamports. Default 0.25 SOL (250,000,000 lamports).
MINT_FEE_LAMPORTS=250000000                     # OPTIONAL (default: 250000000)

# Wallet that receives mint fees. Optional — defaults to the agent PDA
# (derived from AGENT_ASSET_ADDRESS) so fees accumulate in the agent's
# controlled wallet. Override here only if you want fees to land somewhere
# other than the agent's own PDA.
MINT_FEE_RECIPIENT=                             # OPTIONAL (defaults to agent PDA)

# Address of the "Time Machine" MPL Core collection. Created once at deploy
# time via scripts/create-collection.ts; persist the address here.
COLLECTION_ADDRESS=                             # REQUIRED after collection bootstrap

# Cloudflare Turnstile secret key for bot protection on chat.
TURNSTILE_SECRET_KEY=                           # OPTIONAL

# Daily LLM spend ceiling in USD. Beyond this, the chat circuit breaker
# returns a "high traffic" message instead of routing to the LLM.
DAILY_LLM_SPEND_USD_CAP=100                     # OPTIONAL (default: 100)

# Per-IP-per-character chat rate limits.
CHAT_RATE_PER_IP_PER_10MIN=30                   # OPTIONAL (default: 30)
CHAT_RATE_PER_IP_PER_DAY=200                    # OPTIONAL (default: 200)

# Salt used when hashing client IPs before persistence (privacy).
# Optional — defaults to a SHA-256 derivative of WEB_CHANNEL_TOKEN, which
# gives every deploy a unique salt for free. Override only if you need to
# rotate the salt independently.
IP_HASH_SALT=                                   # OPTIONAL (default: derived from WEB_CHANNEL_TOKEN)
